# =============================================================================
# GRCx environment template
# Copy values into:
#   - backend/.env              (local backend)
#   - frontend/.env.local       (local Vite)
#   - Railway / Vercel dashboards (production)
# Never commit real secrets.
# =============================================================================

# --- Shared ---
GRCX_ENV=development
SECRET_KEY=dev-only-change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Postgres ---
POSTGRES_USER=grcx
POSTGRES_PASSWORD=grcx_local_dev_change_me
POSTGRES_DB=grcx
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://grcx:grcx_local_dev_change_me@localhost:5432/grcx

# Local zero-deps mode (omit DATABASE_URL / set USE_SQLITE=true)
# USE_SQLITE=true
# SQLITE_PATH=./grcx_local.db

# --- Backend (FastAPI) ---
# Local default port 8002; Docker/Railway use PORT.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8002
# PORT=8000
CORS_ORIGINS=http://localhost:5174,http://localhost:5173,http://127.0.0.1:5174,http://127.0.0.1:5173

# Frontend → Backend only. Backend → AI service.
AI_PROVIDER=imtithal
AI_SERVICE_URL=http://127.0.0.1:8001
AI_SERVICE_TOKEN=change-me-generate-with-openssl-rand-base64-32
AI_REQUEST_TIMEOUT_SECONDS=120

# Legacy local_http provider (not used when AI_PROVIDER=imtithal)
LOCAL_AI_BASE_URL=http://127.0.0.1:11434
LOCAL_AI_MODEL=grcx-local

# --- AI service (Imtithal) ---
AI_HOST=127.0.0.1
AI_PORT=8001
# Railway: PORT is injected; AI_HOST must be 0.0.0.0
# AI_HOST=0.0.0.0

# Ollama (AI service → Ollama). Prefer OLLAMA_BASE_URL in production.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
# Optional aliases still honored:
# IMTITHAL_OLLAMA_MODEL=qwen2.5:3b
# RAQEEB_OLLAMA_MODEL=qwen2.5:3b

# AraBERT weights are gitignored (*.safetensors). For Railway, place
# model.safetensors on a volume and set:
# ARABERT_WEIGHTS_SRC=/data/arabert/model.safetensors

TRANSLATION_ENABLED=true
TRANSLATION_PROVIDER=glossary
MODEL_LANGUAGE=ar

# --- Frontend (Vite) — copy to frontend/.env.local ---
# Browser must call ONLY the public backend URL (never AI or Ollama).
VITE_API_BASE_URL=http://localhost:8002/api/v1
VITE_USE_MOCKS=false

# Demo login (seeded by backend bootstrap): test@grcx.local / 123456

# =============================================================================
# Production sketch (Railway private networking + Vercel)
# =============================================================================
# GRCX_ENV=production
# SECRET_KEY=<openssl rand -hex 32>
# CORS_ORIGINS=https://<your-vercel-app>.vercel.app
# DATABASE_URL=${{Postgres.DATABASE_URL}}   # use Railway Postgres plugin URL + psycopg scheme
# AI_PROVIDER=imtithal
# AI_SERVICE_URL=http://<ai-service>.railway.internal:${{AI.PORT}}
# AI_SERVICE_TOKEN=<shared secret>
# OLLAMA_BASE_URL=http://ollama.railway.internal:11434
# OLLAMA_MODEL=qwen2.5:3b
# VITE_API_BASE_URL=https://<backend-public>.up.railway.app/api/v1
# VITE_USE_MOCKS=false
