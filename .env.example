# =============================================================================
# GRCx environment template
# Copy values into:
#   - backend/.env              (local backend)
#   - frontend/.env.local       (local Vite)
#   - Railway / Vercel dashboards (production)
# Never commit real secrets.
# =============================================================================

# --- Shared ---
GRCX_ENV=development
SECRET_KEY=dev-only-change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Postgres ---
POSTGRES_USER=grcx
POSTGRES_PASSWORD=grcx_local_dev_change_me
POSTGRES_DB=grcx
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://grcx:grcx_local_dev_change_me@localhost:5432/grcx

# Local zero-deps mode (omit DATABASE_URL / set USE_SQLITE=true)
# USE_SQLITE=true
# SQLITE_PATH=./grcx_local.db

# --- Backend (FastAPI) ---
# Local default port 8002; Docker/Railway use PORT.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8002
# PORT=8000
CORS_ORIGINS=http://localhost:5174,http://localhost:5173,http://127.0.0.1:5174,http://127.0.0.1:5173

# Railway production (exact variable name read by backend Settings.cors_origins):
# CORS_ORIGINS=https://grcx-ashy.vercel.app,http://localhost:5173,http://localhost:5174
# Never set CORS_ORIGINS=* when using cookie credentials.

# Frontend → Backend only. Backend → Ollama (local_http) or AI service (imtithal).
# Production (Railway backend talking to private Ollama):
AI_PROVIDER=local_http
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:0.5b
AI_REQUEST_TIMEOUT_SECONDS=120

# Optional Imtithal AI service path (AraBERT + RAG) — not required for Ollama chat:
# AI_PROVIDER=imtithal
# AI_SERVICE_URL=http://127.0.0.1:8001
# AI_SERVICE_TOKEN=change-me-generate-with-openssl-rand-base64-32

# Legacy aliases (optional; OLLAMA_* takes precedence for local_http):
# LOCAL_AI_BASE_URL=http://127.0.0.1:11434
# LOCAL_AI_MODEL=qwen2.5:0.5b

# --- AI service (Imtithal) — only when AI_PROVIDER=imtithal ---
AI_HOST=127.0.0.1
AI_PORT=8001
# Railway: PORT is injected; AI_HOST must be 0.0.0.0
# AI_HOST=0.0.0.0

# Ollama URL alias still read by the AI service package:
OLLAMA_URL=http://127.0.0.1:11434
# Optional aliases still honored by the AI service package:
# IMTITHAL_OLLAMA_MODEL=qwen2.5:0.5b
# RAQEEB_OLLAMA_MODEL=qwen2.5:0.5b

# AraBERT weights are gitignored (*.safetensors). For Railway, place
# model.safetensors on a volume and set:
# ARABERT_WEIGHTS_SRC=/data/arabert/model.safetensors

TRANSLATION_ENABLED=true
TRANSLATION_PROVIDER=glossary
MODEL_LANGUAGE=ar

# --- Frontend (Vite) — copy to frontend/.env.local ---
# Browser must call ONLY the public backend URL (never AI or Ollama).
VITE_API_BASE_URL=http://localhost:8002/api/v1
VITE_USE_MOCKS=false

# Demo login (seeded by backend bootstrap): test@grcx.local / 123456

# =============================================================================
# Production sketch (Railway private networking + Vercel)
# =============================================================================
# GRCX_ENV=production
# SECRET_KEY=<openssl rand -hex 32>
# CORS_ORIGINS=https://grcx-ashy.vercel.app,http://localhost:5173,http://localhost:5174
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# Backend → private Ollama (required for AI Advisor on Vercel):
# AI_PROVIDER=local_http
# OLLAMA_BASE_URL=http://ollama.railway.internal:11434
# OLLAMA_MODEL=qwen2.5:0.5b
# AI_REQUEST_TIMEOUT_SECONDS=120
# Vercel build-time (host only is OK — frontend appends /api/v1):
# VITE_API_BASE_URL=https://grcx-production.up.railway.app
# VITE_USE_MOCKS=false
# VITE_DEMO_MODE=true
# Railway backend (hackathon showcase — restricted demo session):
# DEMO_MODE=true
