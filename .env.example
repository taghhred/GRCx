# GRCx local environment

# --- Postgres (Docker compose) ---
POSTGRES_USER=grcx
POSTGRES_PASSWORD=grcx_local_dev_change_me
POSTGRES_DB=grcx
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Backend (local without Docker uses port 8002) ---
GRCX_ENV=development
SECRET_KEY=dev-only-change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5174,http://localhost:5173
DATABASE_URL=postgresql+psycopg://grcx:grcx_local_dev_change_me@localhost:5432/grcx

# --- AI (local without Docker) ---
# Frontend → Backend :8002 → AI :8001
AI_PROVIDER=raqeeb
AI_SERVICE_URL=http://127.0.0.1:8001
AI_SERVICE_TOKEN=change-me-generate-with-openssl-rand-base64-32
AI_REQUEST_TIMEOUT_SECONDS=120
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8002

# --- AI (Docker compose — when Docker is available) ---
# AI_SERVICE_URL=http://ai:8090
# AI_PORT=8090

TRANSLATION_ENABLED=true
TRANSLATION_PROVIDER=glossary
MODEL_LANGUAGE=ar
OLLAMA_URL=http://127.0.0.1:11434

# --- Frontend (copy to frontend/.env.local) ---
VITE_API_BASE_URL=http://127.0.0.1:8002/api/v1
VITE_USE_MOCKS=false

# Demo login (seeded by backend bootstrap): test@grcx.local / 123456
