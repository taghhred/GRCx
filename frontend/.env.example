# Frontend — talk to local FastAPI with cookie sessions
# Local backend listens on 8002 (8000 is reserved/stuck on some Windows hosts).
# Use localhost (not 127.0.0.1) when the Vite app is opened at http://localhost:5173
# so HttpOnly auth cookies are same-site and /auth/me works after login.
VITE_API_BASE_URL=http://localhost:8002/api/v1
VITE_USE_MOCKS=false
