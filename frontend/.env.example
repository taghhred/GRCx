# Frontend env template — copy to .env.local for local dev.
#
# Browser → public Backend only. Never point these at the AI service or Ollama.

# Local
VITE_API_BASE_URL=http://localhost:8002/api/v1
VITE_USE_MOCKS=false

# Production (Vercel project env — set at build time)
# VITE_API_BASE_URL=https://<your-backend>.up.railway.app/api/v1
# VITE_USE_MOCKS=false
